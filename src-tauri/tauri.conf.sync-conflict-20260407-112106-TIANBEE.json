{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Pascal",
  "version": "0.1.0",
  "identifier": "com.pascal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pascal",
        "width": 1200,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://cdn.akamai.steamstatic.com https://steamcdn-a.akamaihd.net data:; connect-src 'self' https://api.steampowered.com https://store.steampowered.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
