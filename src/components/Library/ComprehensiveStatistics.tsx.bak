import { useEffect } from "react";
import { useComprehensiveStatistics } from "../../hooks/useComprehensiveStatistics";
import { useI18n } from "../../i18n";

// Status display labels with colors
const STATUS_COLORS: Record<string, { bg: string; text: string; bar: string }> = {
  'not_started': { bg: 'bg-gray-600', text: 'text-gray-400', bar: 'bg-gray-500' },
  'playing': { bg: 'bg-blue-600', text: 'text-blue-400', bar: 'bg-blue-500' },
  'completed': { bg: 'bg-green-600', text: 'text-green-400', bar: 'bg-green-500' },
  'dropped': { bg: 'bg-red-600', text: 'text-red-400', bar: 'bg-red-500' },
  'wishlist': { bg: 'bg-purple-600', text: 'text-purple-400', bar: 'bg-purple-500' },
};

const STATUS_LABELS: Record<string, string> = {
  'not_started': 'Not Started',
  'playing': 'Playing',
  'completed': 'Completed',
  'dropped': 'Dropped',
  'wishlist': 'Wishlist',
};

// Platform icons
const PLATFORM_ICONS: Record<string, string> = {
  'pc': '💻',
  'playstation': '🎮',
  'xbox': '🎯',
  'nintendo': '🕹️',
  'mobile': '📱',
  'other': '📟',
};

export function ComprehensiveStatistics() {
  const { t } = useI18n();
  const { stats, loading, error, fetchStatistics } = useComprehensiveStatistics();

  useEffect(() => {
    fetchStatistics();
  }, [fetchStatistics]);

  if (loading) {
    return (
      <div className="flex items-center justify-center py-12">
        <div className="theme-text-muted flex items-center gap-2">
          <div className="w-5 h-5 border-2 border-current border-t-transparent rounded-full animate-spin" />
          Loading statistics...
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="flex items-center justify-center py-12">
        <div className="text-red-400">Error: {error}</div>
      </div>
    );
  }

  if (!stats) {
    return (
      <div className="flex items-center justify-center py-12">
        <div className="theme-text-muted">No statistics available</div>
      </div>
    );
  }

  const formatHours = (hours: number) => {
    if (hours < 1) return `${(hours * 60).toFixed(0)} min`;
    if (hours < 24) return `${hours.toFixed(1)}h`;
    return `${(hours / 24).toFixed(1)}d`;
  };

  const StatCard = ({ title, value, subtitle, icon, color = "indigo" }: { 
    title: string; 
    value: string | number; 
    subtitle?: string;
    icon?: string;
    color?: "indigo" | "blue" | "green" | "purple" | "orange" | "red" | "yellow";
  }) => {
    const colorClasses = {
      indigo: "from-indigo-600 to-purple-700",
      blue: "from-blue-600 to-cyan-700",
      green: "from-green-600 to-emerald-700",
      purple: "from-purple-600 to-pink-700",
      orange: "from-orange-600 to-red-700",
      red: "from-red-600 to-rose-700",
      yellow: "from-yellow-600 to-orange-700",
    };

    return (
      <div className={`theme-bg-secondary p-4 rounded-lg border theme-border hover:border-${color}-500/50 transition-colors`}>
        <div className="flex items-start justify-between">
          <div>
            <div className="text-sm theme-text-secondary mb-1">{title}</div>
            <div className={`text-3xl font-bold bg-gradient-to-r ${colorClasses[color]} bg-clip-text text-transparent`}>
              {value}
            </div>
            {subtitle && <div className="text-xs theme-text-muted mt-1">{subtitle}</div>}
          </div>
          {icon && <span className="text-2xl opacity-50">{icon}</span>}
        </div>
      </div>
    );
  };

  return (
    <div className="p-6 space-y-6 max-h-[80vh] overflow-y-auto">
      <div className="flex items-center justify-between">
        <h2 className="text-2xl font-bold theme-text-primary">
          📊 {t('comprehensiveStatistics') || "Comprehensive Statistics"}
        </h2>
        <button
          onClick={fetchStatistics}
          className="px-3 py-1.5 text-sm bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors"
        >
          🔄 {t('refresh')}
        </button>
      </div>

      {/* Overview Section */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatCard 
          title={t('totalGames') || "Total Games"}
          value={stats.total_games}
          subtitle={`${stats.games_with_igdb} with IGDB`}
          icon="🎮"
          color="indigo"
        />
        <StatCard 
          title={t('totalPlayTime') || "Total Play Time"}
          value={formatHours(stats.total_play_time)}
          subtitle={`${stats.avg_play_time.toFixed(1)}h avg`}
          icon="⏱️"
          color="blue"
        />
        <StatCard 
          title={t('favoriteGames') || "Favorites"}
          value={stats.favorite_games}
          subtitle={`${((stats.favorite_games / stats.total_games) * 100).toFixed(0)}% of library`}
          icon="⭐"
          color="yellow"
        />
        <StatCard 
          title={t('ratedGames') || "Rated Games"}
          value={stats.rated_games}
          subtitle={`Avg: ${stats.avg_personal_rating.toFixed(1)}/10`}
          icon="⭐"
          color="purple"
        />
      </div>

      {/* Library Health */}
      <div className="theme-bg-secondary p-4 rounded-lg">
        <h3 className="text-lg font-semibold theme-text-primary mb-4">
          🏥 {t('libraryHealth') || "Library Health"}
        </h3>
        <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div className="flex items-center gap-3 p-3 theme-bg-tertiary rounded-lg">
            <div className="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center text-green-400">
              {((stats.games_with_igdb / stats.total_games) * 100).toFixed(0)}%
            </div>
            <div>
              <div className="text-sm theme-text-secondary">{t('matchedWithIgdb') || "IGDB Matched"}</div>
              <div className="text-lg font-bold theme-text-primary">{stats.games_with_igdb}</div>
            </div>
          </div>
          <div className="flex items-center gap-3 p-3 theme-bg-tertiary rounded-lg">
            <div className="w-10 h-10 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400">
              {((stats.games_with_covers / stats.total_games) * 100).toFixed(0)}%
            </div>
            <div>
              <div className="text-sm theme-text-secondary">{t('withCovers') || "With Covers"}</div>
              <div className="text-lg font-bold theme-text-primary">{stats.games_with_covers}</div>
            </div>
          </div>
          <div className="flex items-center gap-3 p-3 theme-bg-tertiary rounded-lg">
            <div className="w-10 h-10 rounded-full bg-orange-500/20 flex items-center justify-center text-orange-400">
              {((stats.games_with_executable / stats.total_games) * 100).toFixed(0)}%
            </div>
            <div>
              <div className="text-sm theme-text-secondary">{t('withExecutable') || "With Executable"}</div>
              <div className="text-lg font-bold theme-text-primary">{stats.games_with_executable}</div>
            </div>
          </div>
        </div>
      </div>

      {/* Completion Status */}
      {stats.completion_stats.length > 0 && (
        <div className="theme-bg-secondary p-4 rounded-lg">
          <h3 className="text-lg font-semibold theme-text-primary mb-4">
            📊 {t('gamesByStatus') || "Games by Status"}
          </h3>
          <div className="space-y-3">
            {stats.completion_stats.map(([status, count]) => {
              const colors = STATUS_COLORS[status] || STATUS_COLORS['not_started'];
              const percentage = ((count / stats.total_games) * 100).toFixed(1);
              return (
                <div key={status} className="flex items-center gap-3">
                  <div className={`w-3 h-3 rounded-full ${colors.bg}`} />
                  <span className={`w-24 text-sm ${colors.text}`}>
                    {STATUS_LABELS[status] || status}
                  </span>
                  <div className="flex-1 theme-bg-tertiary rounded-full h-5 overflow-hidden">
                    <div 
                      className={`h-full ${colors.bar} transition-all duration-500`}
                      style={{ width: `${(count / stats.total_games) * 100}%` }}
                    />
                  </div>
                  <span className="theme-text-primary font-medium w-16 text-right">{count}</span>
                  <span className="theme-text-muted text-xs w-12">{percentage}%</span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Platform Distribution */}
      {stats.platform_stats.length > 0 && (
        <div className="theme-bg-secondary p-4 rounded-lg">
          <h3 className="text-lg font-semibold theme-text-primary mb-4">
            🎮 {t('gamesByPlatform') || "Games by Platform"}
          </h3>
          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            {stats.platform_stats.map(([platform, count]) => (
              <div 
                key={platform}
                className="flex items-center justify-between p-3 theme-bg-tertiary rounded-lg hover:bg-indigo-600/10 transition-colors"
              >
                <div className="flex items-center gap-2">
                  <span className="text-xl">{PLATFORM_ICONS[platform] || '📟'}</span>
                  <span className="theme-text-secondary capitalize">{platform}</span>
                </div>
                <span className="theme-text-primary font-bold">{count}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Top Genres */}
      {stats.genre_stats.length > 0 && (
        <div className="theme-bg-secondary p-4 rounded-lg">
          <h3 className="text-lg font-semibold theme-text-primary mb-4">
            🎭 {t('topGenres') || "Top Genres"}
          </h3>
          <div className="flex flex-wrap gap-2">
            {stats.genre_stats.map(([genre, count], index) => (
              <div 
                key={genre}
                className={`px-3 py-1.5 rounded-full text-sm font-medium ${
                  index < 3 
                    ? 'bg-indigo-600/20 text-indigo-400 border border-indigo-600/30' 
                    : 'theme-bg-tertiary theme-text-secondary'
                }`}
              >
                {genre}: {count}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Top Tags */}
      {stats.top_tags.length > 0 && (
        <div className="theme-bg-secondary p-4 rounded-lg">
          <h3 className="text-lg font-semibold theme-text-primary mb-4">
            🏷️ {t('topTags') || "Top Tags"}
          </h3>
          <div className="flex flex-wrap gap-2">
            {stats.top_tags.map(([tag, count], index) => (
              <div 
                key={tag}
                className={`px-3 py-1.5 rounded-full text-sm ${
                  index < 3 
                    ? 'bg-purple-600/20 text-purple-400 border border-purple-600/30' 
                    : 'theme-bg-tertiary theme-text-secondary'
                }`}
              >
                #{tag}: {count}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Collections */}
      {stats.collection_stats.length > 0 && (
        <div className="theme-bg-secondary p-4 rounded-lg">
          <h3 className="text-lg font-semibold theme-text-primary mb-4">
            📚 {t('collections') || "Collections"} ({stats.total_collections})
          </h3>
          <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
            {stats.collection_stats.map(([name, count]) => (
              <div key={name} className="flex items-center justify-between p-2 theme-bg-tertiary rounded">
                <span className="theme-text-secondary text-sm truncate">{name}</span>
                <span className="theme-text-primary font-medium">{count}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Release Years */}
      {stats.release_years.length > 0 && (
        <div className="theme-bg-secondary p-4 rounded-lg">
          <h3 className="text-lg font-semibold theme-text-primary mb-4">
            📅 {t('gamesByYear') || "Games by Release Year"}
          </h3>
          <div className="h-32 flex items-end gap-1">
            {stats.release_years.slice(0, 20).map(([year, count]) => {
              const maxCount = Math.max(...stats.release_years.map(([, c]) => c));
              const height = (count / maxCount) * 100;
              return (
                <div key={year} className="flex-1 flex flex-col items-center gap-1">
                  <div 
                    className="w-full bg-indigo-600/50 rounded-t hover:bg-indigo-500 transition-colors relative group"
                    style={{ height: `${height}%`, minHeight: '4px' }}
                  >
                    <div className="absolute -top-6 left-1/2 -translate-x-1/2 bg-gray-800 px-2 py-1 rounded text-xs text-white opacity-0 group-hover:opacity-100 whitespace-nowrap z-10">
                      {year}: {count}
                    </div>
                  </div>
                  <span className="text-xs theme-text-muted rotate-0">{year.slice(2)}</span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* System Stats */}
      <div className="theme-bg-secondary p-4 rounded-lg">
        <h3 className="text-lg font-semibold theme-text-primary mb-4">
          ⚙️ {t('systemStats') || "System Statistics"}
        </h3>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
          <div className="p-3 theme-bg-tertiary rounded-lg text-center">
            <div className="text-2xl font-bold theme-text-primary">{stats.total_scanned_folders}</div>
            <div className="theme-text-muted">{t('scannedFolders') || "Scanned Folders"}</div>
          </div>
          <div className="p-3 theme-bg-tertiary rounded-lg text-center">
            <div className="text-2xl font-bold theme-text-primary">{stats.total_exclusions}</div>
            <div className="theme-text-muted">{t('exclusionPatterns') || "Exclusion Patterns"}</div>
          </div>
          <div className="p-3 theme-bg-tertiary rounded-lg text-center">
            <div className="text-2xl font-bold theme-text-primary">{stats.total_tags}</div>
            <div className="theme-text-muted">{t('totalTags') || "Total Tags"}</div>
          </div>
          <div className="p-3 theme-bg-tertiary rounded-lg text-center">
            <div className="text-2xl font-bold theme-text-primary">{stats.total_screenshots}</div>
            <div className="theme-text-muted">{t('screenshots') || "Screenshots"}</div>
          </div>
        </div>
      </div>

      {/* Search Stats */}
      <div className="theme-bg-secondary p-4 rounded-lg">
        <h3 className="text-lg font-semibold theme-text-primary mb-4">
          🔍 {t('searchStats') || "Search Statistics"}
        </h3>
        <div className="grid grid-cols-2 gap-4">
          <div className="flex items-center justify-between p-3 theme-bg-tertiary rounded-lg">
            <span className="theme-text-secondary">{t('totalSearches') || "Total Searches"}</span>
            <span className="text-xl font-bold theme-text-primary">{stats.total_searches}</span>
          </div>
          <div className="flex items-center justify-between p-3 theme-bg-tertiary rounded-lg">
            <span className="theme-text-secondary">{t('uniqueQueries') || "Unique Queries"}</span>
            <span className="text-xl font-bold theme-text-primary">{stats.unique_searches}</span>
          </div>
        </div>
      </div>

      {/* Footer */}
      <div className="text-center theme-text-muted text-sm py-4">
        {stats.recently_added > 0 && (
          <p>📈 {t('recentlyAddedCount').replace('{{count}}', String(stats.recently_added)) || `${stats.recently_added} games added in the last 30 days`}</p>
        )}
      </div>
    </div>
  );
}
